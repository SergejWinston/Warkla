FLASK_ENV=development
SECRET_KEY=change-me-to-random-secret
JWT_SECRET_KEY=change-me-to-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES_DAYS=30

# Database configuration
DATABASE_URL=sqlite:///ege.db

# CORS settings
CORS_ORIGINS=*

# File upload settings
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=5242880

FLASK_API_BASE=http://localhost:5000/api

# Redis configuration (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# NeoFamily API settings
NEOFAMILY_API_BASE=https://backend.neofamily.ru/api
NEOFAMILY_SYNC_ENABLED=true
NEOFAMILY_BOOTSTRAP_PAGES=15
NEOFAMILY_BOOTSTRAP_PER_PAGE=15
NEOFAMILY_PERIODIC_PAGES=2
NEOFAMILY_SYNC_INTERVAL_SECONDS=21600

# Domain configuration
DOMAIN=localhost

# Flask settings
FLASK_APP=run.py

