FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_TOKEN_EXPIRES_DAYS=30

# Persist database in Docker volume mounted at /app/instance
DATABASE_URL=sqlite:////app/instance/warkla.db

CORS_ORIGINS=*
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=5242880

# Used by deploy script to render nginx config
DOMAIN=localhost

# Optional, useful for flask commands in container
FLASK_APP=run.py
